{
  "name": "base44-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "seed:acme-demo": "node scripts/seed_acme_demo.cjs",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "env:local": "bash ./scripts/use-env-profile.sh local",
    "env:remote-test": "bash ./scripts/use-env-profile.sh remote-test",
    "verify:release": "npm run lint && npm run build && npm run check:no-radix && npm run check:no-docs-support && npm run check:no-beta-waitlist && npm run check:no-legacy-item-contracts && npm run check:no-board-runtime && npm run check:no-stale-function-artifacts",
    "check:no-radix": "! rg -n \"@radix-ui/\" src",
    "check:no-docs-support": "! rg -n \"SupportThread|SupportMessage|support_enabled|doc_page|support_thread|doc_comment|createSupport|createDocComment|publicGetDoc|author_role\\s*:\\s*'support'|role\\s*[:=]=?\\s*'support'|/support|/docs|/Support|/Docs|DocsLegacy|SupportLegacy\" src supabase/functions supabase/migrations",
    "check:no-beta-waitlist": "! rg -n -i \"beta|waitlist|setBetaAccess|publicWaitlistSignup\" src supabase/functions supabase/migrations README.md",
    "check:no-legacy-item-contracts": "! rg -n \"entities\\.(Feedback|FeedbackResponse|RoadmapItem|RoadmapUpdate|ChangelogEntry)|publicGetFeedback|publicGetRoadmap|publicGetChangelog|createFeedback|createRoadmap|updateFeedback|updateRoadmap\" src app supabase/functions",
    "check:no-board-runtime": "! rg -n \"\\bboard\\b|\\bboards\\b|board_|\\bBoard\\b|/board/|createBoard|checkBoardSlug|publicGetBoard|joinBoardWithAccessCode|getBoardAccessCodeStatus|setBoardAccessCode|publicTrackBoardView\" src app supabase/functions .github/workflows README.md RELEASE_HANDOFF.md",
    "check:no-stale-function-artifacts": "! rg -n \"createFeedback|updateFeedback|createRoadmap|updateRoadmap|publicGetFeedback|publicGetRoadmap|publicGetChangelog|publicGetDocs|createSupport|publicWaitlistSignup|setBetaAccess|recordInteraction|reportUsage\" supabase/functions src",
    "typecheck": "tsc -p ./jsconfig.json"
  },
  "dependencies": {
    "@base44/sdk": "^0.8.3",
    "@hello-pangea/dnd": "^17.0.0",
    "@hookform/resolvers": "^4.1.2",
    "@stripe/react-stripe-js": "^3.0.0",
    "@stripe/stripe-js": "^5.2.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.90.1",
    "@tanstack/react-query": "^5.84.1",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.5.2",
    "framer-motion": "^11.16.4",
    "html2canvas": "^1.4.1",
    "input-otp": "^1.4.2",
    "jspdf": "^2.5.2",
    "lodash": "^4.17.21",
    "lucide-react": "^0.475.0",
    "moment": "^2.30.1",
    "next": "^15.2.0",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^9.0.1",
    "react-quill": "^2.0.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.4",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.171.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@types/node": "^22.13.5",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.20",
    "baseline-browser-mapping": "^2.8.32",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^15.14.0",
    "postcss": "^8.5.3",
    "supabase": "^2.72.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}

# Local Supabase profile (supabase start)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<local-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<local-service-role-key>
NEXT_PUBLIC_AUTH_PROVIDER=dev

# Optional app identifiers
NEXT_PUBLIC_BASE44_APP_ID=local
NEXT_PUBLIC_BASE44_FUNCTIONS_VERSION=v1
NEXT_PUBLIC_BASE44_APP_BASE_URL=http://127.0.0.1:3000
